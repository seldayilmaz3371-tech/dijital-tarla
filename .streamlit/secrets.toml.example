# =============================================================
# secrets.toml ŞABLONU
# =============================================================
# 1) Bu dosyayı ".streamlit/secrets.toml" olarak KOPYALAYIN (rename değil, kopya).
# 2) Aşağıdaki "your-..." alanlarını gerçek API anahtarlarınızla değiştirin.
# 3) secrets.toml dosyasını .gitignore'a ekleyin, ASLA repoya (GitHub) push etmeyin.
# 4) Streamlit Cloud kullanıyorsanız: aynı içeriği App Settings > Secrets
#    bölümüne yapıştırmanız yeterli, dosyaya gerek kalmaz.
# =============================================================

GEMINI_API_KEY  = "your-gemini-api-key-here"
OPENAI_API_KEY  = "your-openai-api-key-here"
TAVILY_API_KEY  = "your-tavily-api-key-here"
SERPAPI_API_KEY = "your-serpapi-api-key-here"